{
    "name": "module1/catalog-module",
    "description": "Catalog module for the Laravel modular monolith homework",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Module1\\CatalogModule\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Module1\\CatalogModule\\CatalogServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/view": "^12.0",
        "illuminate/database": "^12.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}