{
    "name": "module2/campaigns-module",
    "description": "Campaign notifications module for the Laravel modular monolith homework",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Module2\\CampaignsModule\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Module2\\CampaignsModule\\CampaignsServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/view": "^12.0",
        "illuminate/database": "^12.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}